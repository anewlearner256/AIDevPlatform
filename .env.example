# 应用配置
APP_NAME="AI自动开发平台"
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-in-production
API_PREFIX=/api/v1

# 数据库配置
DATABASE_URL=postgresql://user:password@localhost:5432/aidevplatform
DATABASE_TEST_URL=postgresql://user:password@localhost:5432/aidevplatform_test

# Redis配置
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# LLM配置
CLAUDE_API_KEY=your-claude-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-3-small

# 向量数据库
CHROMA_PERSIST_DIR=./chroma-data
CHROMA_COLLECTION_NAME=knowledge_base

# 执行引擎配置
DOCKER_NETWORK=aidev-sandbox
EXECUTION_TIMEOUT=300
MAX_MEMORY_LIMIT=1g
MAX_CPU_LIMIT=1.0

# 任务队列
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS配置
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# 文件上传配置
MAX_UPLOAD_SIZE=104857600  # 100MB
UPLOAD_DIR=./uploads
KNOWLEDGE_BASE_DIR=./knowledge_base